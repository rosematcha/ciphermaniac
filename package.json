{
  "name": "ciphermaniac",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Pokemon TCG tournament data visualization tool",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --project tsconfig.frontend.json",
    "typecheck:backend": "tsc --noEmit --project tsconfig.json",
    "typecheck:node": "tsc --noEmit --project tsconfig.node.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "validate": "npm run typecheck && npm run typecheck:backend && npm run typecheck:node && npm run lint",
    "validate:fix": "npm run lint:fix && npm run typecheck",
    "test": "npm run test:unit",
    "test:all": "npm run test:unit",
    "test:unit": "node --test --import tsx tests/security/*.test.ts tests/data/*.test.ts tests/shared/*.test.ts tests/utils/*.test.ts",
    "test:api": "node --test --import tsx tests/api/*.test.ts",
    "test:coverage": "c8 npm run test:unit",
    "test:mobile": "playwright test",
    "images:convert": "tsx scripts/convert-card-images.ts",
    "build:card-types": "node scripts/build-card-types.mjs",
    "check:card-types": "node scripts/check-card-types.mjs",
    "bench:routes": "tsx scripts/benchmark-routes.ts",
    "prepare": "husky",
    "knip": "knip"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.928.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "c8": "^10.1.3",
    "cheerio": "^1.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-solid": "^0.14.5",
    "husky": "^9.1.7",
    "knip": "^6.3.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vite": "^5.4.10",
    "vite-plugin-solid": "^2.11.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pokemon",
    "tcg",
    "tournament",
    "data-visualization",
    "frontend"
  ],
  "author": "Ciphermaniac",
  "license": "MIT",
  "dependencies": {
    "@solidjs/router": "^0.15.0",
    "modern-screenshot": "^4.7.0",
    "solid-js": "^1.9.3"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
