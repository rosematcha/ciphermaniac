{
  "ci": {
    "collect": {
      "startServerCommand": "npx vite preview --port 4173 --strictPort",
      "startServerReadyPattern": "Local",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/cards",
        "http://localhost:4173/trends"
      ],
      "numberOfRuns": 1,
      "settings": {
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 3000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 90000 }],
        "resource-summary:image:size": ["warn", { "maxNumericValue": 600000 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 1500000 }],
        "categories:performance": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
